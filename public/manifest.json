{
  "name": "Ortoni Studio",
  "short_name": "Ortoni Studio",
  "description": "XPath and Selector Finder, simple and useful, open-source project by LetCode with Koushik",
  "author": "Koushik Chatterjee",
  "version": "3.0.2",
  "manifest_version": 3,
  "icons": {
    "16": "assets/16.png",
    "32": "assets/32.png",
    "128": "assets/32.png"
  },
  "host_permissions": ["<all_urls>"],
  "permissions": ["contextMenus", "activeTab", "storage", "notifications"],
  "content_scripts": [
    {
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "matches": ["<all_urls>"],
      "js": ["app/src/content.js"],
      "css": ["app/styles/highlight.css"]
    }
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "devtools_page": "devtools.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "homepage_url": "https://www.letcode.in",
  "options_page": "option/option.html",
  "offline_enabled": true
}
